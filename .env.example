# Copy to .env for local development. Real values in production are set through
# Hostinger's docker-compose/env editor, never committed here (SPEC.md §8).

# Spotify OAuth (Authorization Code Flow) — see SPEC.md §5
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/admin/spotify/callback

# Token encryption key (Fernet), see SPEC.md §8. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Admin session cookie signing key. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=

# Set to true once Hostinger's TLS termination is confirmed (SPEC.md §9/§12.1) — a
# Secure cookie is silently dropped by browsers over plain HTTP, so leave this false
# for local dev and for as long as the app is served over plain HTTP.
SESSION_COOKIE_SECURE=false

# Local dev only — path to the SQLite file (production uses the /data volume, see docker-compose.yml)
DATABASE_PATH=./data/app.db

# Public domain Caddy requests a TLS cert for; unused when running the app directly with uvicorn
DOMAIN=localhost

# Caddyfile site address — see Caddyfile comment and SPEC.md §9/§12.1 for the TLS_MODE decision
SITE_ADDRESS=http://localhost
